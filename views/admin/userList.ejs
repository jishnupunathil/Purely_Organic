<%-include('../partials/adminSidebar.ejs')-%>
<main class="main-wrap bg-light" style="min-height: 100vh;">
  <%-include('../partials/adminHeader.ejs')-%>
  <section class="content-main p-4">
    <div class="content-header mb-4">
      <h2 class="content-title font-weight-bold text-dark mb-1" style="font-family: 'Playfair Display', serif;">User Management</h2>
      <p class="text-muted text-sm mb-0">View registered customers and manage account access</p>
    </div>
    <div class="card border-0 shadow-sm rounded-4">
      <div class="card-body p-4">
        <div class="table-responsive">
          <table class="table align-middle display table-hover w-100" id="userTable">
            <thead class="bg-light">
              <tr>
                <th class="ps-3">#</th>
                <th>User</th>
                <th>Email</th>
                <th>Registered Date</th>
                <th>Status</th>
                <th class="text-end pe-3">Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (allUser && allUser.length > 0) { %>
                <% allUser.reverse().forEach(function(user, index) { %>
                  <tr>
                    <td class="ps-3 text-muted text-xs font-weight-bold"><%= index + 1 %></td>
                    <td>
                      <div class="d-flex align-items-center gap-3">
                        <div class="avatar rounded-3 bg-light border text-dark font-weight-bold d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
                          <%= user.firstname ? user.firstname.charAt(0).toUpperCase() : 'U' %>
                        </div>
                        <div>
                          <h6 class="mb-0 font-weight-bold text-dark text-sm"><%= user.firstname %> <%= user.lastname || '' %></h6>
                          <small class="text-muted text-xs">ID: #<%= user._id.toString().substr(0, 10) %></small>
                        </div>
                      </div>
                    </td>
                    <td class="text-sm"><%= user.email %></td>
                    <td class="text-muted text-xs"><%= new Date(user.createdAt || Date.now()).toLocaleDateString('en-GB') %></td>
                    <td>
                      <% if (user.isblocked) { %>
                        <span class="badge bg-danger rounded-pill px-2.5 py-1 text-xs">Blocked</span>
                      <% } else { %>
                        <span class="badge bg-success rounded-pill px-2.5 py-1 text-xs">Active</span>
                      <% } %>
                    </td>
                    <td class="text-end pe-3">
                      <% if (user.isblocked) { %>
                        <button type="button" class="btn btn-sm btn-success rounded-pill px-3 py-1 font-weight-bold text-xs" onclick="unblockUser('<%-user._id%>')">Unblock User</button>
                      <% } else { %>
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3 py-1 font-weight-bold text-xs" onclick="blockUser('<%-user._id%>')">Block User</button>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
  <%-include('../partials/adminFooter.ejs')%>
</main>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.0.19/dist/sweetalert2.all.min.js"></script>
<script>
  function blockUser(userId) {
    Swal.fire({
      title: 'Block User?',
      text: "This user will lose access to login and placed orders.",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#6e7881',
      confirmButtonText: 'Yes, Block User'
    }).then((result) => {
      if (result.isConfirmed) {
        $.ajax({
          url: "/admin/blockUser/" + userId,
          method: "post",
          success: function() {
            location.reload();
          }
        });
      }
    });
  }

  function unblockUser(userId) {
    Swal.fire({
      title: 'Unblock User?',
      text: "This user will regain account access.",
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#10B981',
      cancelButtonColor: '#6e7881',
      confirmButtonText: 'Yes, Unblock'
    }).then((result) => {
      if (result.isConfirmed) {
        $.ajax({
          url: "/admin/unBlockUser/" + userId,
          method: "post",
          success: function() {
            location.reload();
          }
        });
      }
    });
  }
</script>
