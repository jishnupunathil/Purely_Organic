<%-include('../partials/adminSidebar.ejs')-%>
<main class="main-wrap">
  <%-include('../partials/adminHeader.ejs')-%>
  <section class="content-main p-4">
    <div class="content-header mb-4">
      <div>
        <h2 class="content-title card-title" style="font-family: 'Playfair Display', serif; font-weight: 700; color: #0F4C3A;">Purely Organic Dashboard</h2>
        <p class="text-muted">Real-time store overview, sales metrics & business analytics</p>
      </div>
    </div>
    <div class="row g-4">
      <div class="col-lg-3 col-md-6 mb-4">
        <div class="card card-body shadow-sm border-0 rounded-3" style="background: #ffffff; border-left: 4px solid #0F4C3A !important;">
          <article class="icontext d-flex align-items-center">
            <span class="icon icon-sm rounded-circle mr-3 p-3" style="background: #E6F4EA; color: #0F4C3A;">
              <i class="material-icons md-monetization_on" style="font-size: 24px;"></i>
            </span>
            <div class="text">
              <h6 class="mb-1 text-muted text-uppercase" style="font-size: 11px; font-weight: 700; letter-spacing: 0.5px;">Total Revenue</h6>
              <h3 class="mb-0 font-weight-bold" style="color: #0F4C3A;">₹<%=totalRevenue%></h3>
              <span class="text-xs text-muted">Net gross revenue</span>
            </div>
          </article>
        </div>
      </div>

      <div class="col-lg-3 col-md-6 mb-4">
        <div class="card card-body shadow-sm border-0 rounded-3" style="background: #ffffff; border-left: 4px solid #10B981 !important;">
          <article class="icontext d-flex align-items-center">
            <span class="icon icon-sm rounded-circle mr-3 p-3" style="background: #D1FAE5; color: #10B981;">
              <i class="material-icons md-local_shipping" style="font-size: 24px;"></i>
            </span>
            <div class="text">
              <h6 class="mb-1 text-muted text-uppercase" style="font-size: 11px; font-weight: 700; letter-spacing: 0.5px;">Total Orders</h6>
              <h3 class="mb-0 font-weight-bold" style="color: #10B981;"><%=orderCount%></h3>
              <span class="text-xs text-muted">Processed transactions</span>
            </div>
          </article>
        </div>
      </div>

      <div class="col-lg-3 col-md-6 mb-4">
        <div class="card card-body shadow-sm border-0 rounded-3" style="background: #ffffff; border-left: 4px solid #F59E0B !important;">
          <article class="icontext d-flex align-items-center">
            <span class="icon icon-sm rounded-circle mr-3 p-3" style="background: #FEF3C7; color: #F59E0B;">
              <i class="material-icons md-qr_code" style="font-size: 24px;"></i>
            </span>
            <div class="text">
              <h6 class="mb-1 text-muted text-uppercase" style="font-size: 11px; font-weight: 700; letter-spacing: 0.5px;">Products Instock</h6>
              <h3 class="mb-0 font-weight-bold" style="color: #D97706;"><%=productsCount%></h3>
              <span class="text-xs text-muted">Active items catalog</span>
            </div>
          </article>
        </div>
      </div>

      <div class="col-lg-3 col-md-6 mb-4">
        <div class="card card-body shadow-sm border-0 rounded-3" style="background: #ffffff; border-left: 4px solid #3B82F6 !important;">
          <article class="icontext d-flex align-items-center">
            <span class="icon icon-sm rounded-circle mr-3 p-3" style="background: #DBEAFE; color: #3B82F6;">
              <i class="material-icons md-group" style="font-size: 24px;"></i>
            </span>
            <div class="text">
              <h6 class="mb-1 text-muted text-uppercase" style="font-size: 11px; font-weight: 700; letter-spacing: 0.5px;">Registered Users</h6>
              <h3 class="mb-0 font-weight-bold" style="color: #2563EB;"><%=usersCount%></h3>
              <span class="text-xs text-muted">Active customer base</span>
            </div>
          </article>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-xl-8 col-lg-12">
        <div class="card mb-4">
          <article class="card-body">
            <h5 class="card-title">Payment statistics</h5>
            <canvas id="myGraph" height="100px"></canvas>
          </article>
        </div>
      </div>
      <div class="col-xl-4 col-lg-12">
        <div class="card mb-4">
          <article class="card-body">
            <h5 class="card-title">Order statistics</h5>
            <canvas id="myPie" height="100px"></canvas>
          </article>
        </div>
      </div>
    </div>
  </section>
  <!-- content-main end// -->
  <%-include('../partials/adminFooter.ejs')%>
</main>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.10.25/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.16.9/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.2/html2pdf.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jsreport-browser-client-dist/2.10.0/jsreport.browser-client.min.js"></script>

<script
  type="text/javascript"
  src="https://cdn.datatables.net/buttons/1.7.1/js/dataTables.buttons.min.js"
></script>
<script
  type="text/javascript"
  src="https://cdn.datatables.net/buttons/1.7.1/js/buttons.html5.min.js"
></script>
<script
  type="text/javascript"
  src="https://cdn.datatables.net/buttons/1.7.1/js/buttons.print.min.js"
></script>

<script>
  $(document).ready(function () {
    // Bar Chart
    const ctx1 = document.getElementById("myGraph").getContext("2d");
    var categorie = ["COD", "ONLINE PAYMENTS"];
    var count = [
      "<%=paymentStatitics?.cash_on_delivery%>",
      "<%=paymentStatitics?.online_payment%>",
    ];
    var barColors = ["#e74c3c", "#2ecc71"];
    new Chart(ctx1, {
      type: "polarArea",
      data: {
        labels: categorie,
        datasets: [
          {
            data: count,
            backgroundColor: barColors,
            borderWidth: 1,
            datalabels: {
              align: "end",
              anchor: "end",
              color: "black",
              font: {
                weight: "bold",
              },
              formatter: function (value, context) {
                return value;
              },
            },
          },
        ],
      },
      options: {
        title: {
          display: true,
          text: "Ogani Product Statistics",
        },
        legend: {
          display: false,
        },
      },
    });

    // Pie Chart
    const ctx2 = document.getElementById("myPie").getContext("2d");
    let orderStatus = ["delivered", "placed", "cancelled", "Shipped"];
    let orderCount = [
      "<%= orderData?.delivered %>",
      "<%= orderData?.placed %>",
      "<%= orderData?.cancelled %>",
      "<%= orderData?.Shipped %>",
    ];
    var pieColors = ["#e74c3c", "#2ecc71", "#3498db", "#f1c40f"]; // Updated color palette
    new Chart(ctx2, {
      type: "pie",
      data: {
        labels: orderStatus,
        datasets: [
          {
            backgroundColor: pieColors,
            data: orderCount,
          },
        ],
      },
      options: {
        title: {
          display: true,
          text: "Ogani Order Statistics",
        },
      },
    });
  });
</script>
