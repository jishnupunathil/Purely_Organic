<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    
    <!-- Primary SEO Meta Tags -->
    <title>Purely Organic | Farm-Fresh Organic Groceries & Natural Produce</title>
    <meta name="title" content="Purely Organic | Farm-Fresh Organic Groceries & Natural Produce">
    <meta name="description" content="Shop 100% certified farm-fresh organic vegetables, natural fruits, dairy, and eco-friendly products. Directly sourced from local organic farms to your doorstep with fast delivery.">
    <meta name="keywords" content="organic food, organic vegetables, fresh fruits, natural groceries, organic farming, Purely Organic, farm fresh, eco-friendly produce, buy organic online">
    <meta name="author" content="Purely Organic">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://purelyorganic.com/">

    <!-- Open Graph / Facebook SEO -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://purelyorganic.com/">
    <meta property="og:title" content="Purely Organic | Farm-Fresh Organic Groceries & Natural Produce">
    <meta property="og:description" content="Shop 100% certified farm-fresh organic vegetables, natural fruits, dairy, and eco-friendly products with fast home delivery.">
    <meta property="og:image" content="/images/logo1.png">
    <meta property="og:site_name" content="Purely Organic">

    <!-- Twitter SEO -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://purelyorganic.com/">
    <meta property="twitter:title" content="Purely Organic | Farm-Fresh Organic Groceries">
    <meta property="twitter:description" content="100% certified organic fruits, vegetables & natural produce delivered fresh.">
    <meta property="twitter:image" content="/images/logo1.png">

    <!-- JSON-LD Structured Data Schema for Search Engines -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "GroceryStore",
      "name": "Purely Organic",
      "description": "Farm-fresh 100% certified organic groceries and natural produce.",
      "url": "https://purelyorganic.com",
      "logo": "https://purelyorganic.com/images/logo1.png",
      "priceRange": "₹₹",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://purelyorganic.com/shoppingPage?search={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Favicon -->
    <link rel="shortcut icon" type="image/x-icon" href="/images/logo1.png">

    <!-- CSS Stylesheets -->
    <link rel="stylesheet" href="/css/bootstrap.min.css" type="text/css">
    <link rel="stylesheet" href="/css/font-awesome.min.css" type="text/css">
    <link rel="stylesheet" href="/css/elegant-icons.css" type="text/css">
    <link rel="stylesheet" href="/css/nice-select.css" type="text/css">
    <link rel="stylesheet" href="/css/jquery-ui.min.css" type="text/css">
    <link rel="stylesheet" href="/css/owl.carousel.min.css" type="text/css">
    <link rel="stylesheet" href="/css/slicknav.min.css" type="text/css">
    <link rel="stylesheet" href="/css/style.css" type="text/css">
    <link rel="stylesheet" href="/css/modern-organic.css" type="text/css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap4.min.css">
</head>

<body>
    <%- body %>

    <!-- Unified Script Imports (Single load to eliminate lag & script conflict) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <!-- Theme Plugins -->
    <script src="/js/jquery.nice-select.min.js"></script>
    <script src="/js/jquery-ui.min.js"></script>
    <script src="/js/jquery.slicknav.js"></script>
    <script src="/js/mixitup.min.js"></script>
    <script src="/js/owl.carousel.min.js"></script>
    <script src="/js/main.js"></script>

    <script>
        $(document).ready(function () {
          if ($('#orderListTable').length) $('#orderListTable').DataTable({ responsive: true });
          if ($('#userTable').length) $('#userTable').DataTable({ responsive: true });
        });

        const OrganicToast = Swal.mixin({
          toast: true,
          position: 'top-end',
          showConfirmButton: false,
          timer: 2500,
          timerProgressBar: true,
          customClass: {
            popup: 'swal2-toast-organic'
          }
        });

        function bumpBadge(badgeSelector) {
          const badges = $(badgeSelector);
          badges.addClass('badge-bump');
          setTimeout(() => badges.removeClass('badge-bump'), 400);
        }

        function addToCart(prodId) {
          $.ajax({
            url: "/user/addtocart/" + prodId,
            method: "POST",
            headers: { 'Accept': 'application/json' },
            success: function(response) {
              if (response.status) {
                OrganicToast.fire({
                  icon: 'success',
                  title: 'Added to Cart! 🌿'
                });
                if (typeof response.cartCount !== 'undefined') {
                  $('.cart-badge').text(response.cartCount);
                } else {
                  const curr = parseInt($('.cart-badge').first().text() || '0');
                  $('.cart-badge').text(curr + 1);
                }
                bumpBadge('.cart-badge');
              } else {
                OrganicToast.fire({
                  icon: 'error',
                  title: response.message || 'Could not add to cart'
                });
              }
            },
            error: function(err) {
              OrganicToast.fire({
                icon: 'error',
                title: err.responseJSON?.message || 'Please login to add to cart'
              });
            }
          });
        }

        function AddToWishList(prodId) {
          $.ajax({
            url: "/user/wishlist/" + prodId,
            method: "POST",
            success: function(response) {
              if (response.removeSuccess) {
                OrganicToast.fire({
                  icon: 'info',
                  title: 'Removed from Wishlist'
                });
                const curr = parseInt($('.wish-badge').first().text() || '1');
                $('.wish-badge').text(Math.max(0, curr - 1));
                bumpBadge('.wish-badge');
              } else if (response.success) {
                OrganicToast.fire({
                  icon: 'success',
                  title: 'Added to Wishlist! ❤️'
                });
                const curr = parseInt($('.wish-badge').first().text() || '0');
                $('.wish-badge').text(curr + 1);
                bumpBadge('.wish-badge');
              } else {
                OrganicToast.fire({
                  icon: 'error',
                  title: 'Could not update wishlist'
                });
              }
            },
            error: function(err) {
              OrganicToast.fire({
                icon: 'error',
                title: 'Please login to add to wishlist'
              });
            }
          });
        }

        function addToCartFromWish(product_id) {
          $.ajax({
            url: `/user/add-to-cartFromWishL/${product_id}`,
            method: "PUT",
            success: function (response) {
              if (response.status) {
                OrganicToast.fire({
                  icon: 'success',
                  title: 'Added to Cart!'
                });
                setTimeout(() => location.reload(), 1000);
              } else {
                OrganicToast.fire({
                  icon: 'error',
                  title: 'Out of stock!'
                });
              }
            }
          });
        }

        function removeFromWishList(product_id) {
          Swal.fire({
            title: `Remove from wishlist?`,
            icon: "question",
            showCancelButton: true,
            confirmButtonText: "Yes, remove",
            confirmButtonColor: "#0F4C3A",
          }).then((result) => {
            if (result.isConfirmed) {
              $.ajax({
                url: "/user/remove-product-from-wishList",
                data: { product: product_id },
                method: "delete",
                success: (response) => {
                  if (response) {
                    location.reload();
                  }
                }
              });
            }
          });
        }
    </script>
</body>
</html>