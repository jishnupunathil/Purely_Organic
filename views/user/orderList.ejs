<%-include('../partials/userHeader.ejs') %>

<main class="bg-light pb-5" style="min-height: 80vh;">
  <!-- Page Banner -->
  <section class="py-4 text-white text-center rounded-3 mb-4 mx-3 shadow-sm" style="background: linear-gradient(135deg, #093327 0%, #0F4C3A 100%);">
    <div class="container">
      <h1 class="font-weight-bold text-white mb-1" style="font-family: 'Playfair Display', serif; font-size: 32px;">Order Details</h1>
      <p class="text-white-50 text-sm mb-0">Order #<%= orderInfo._id.toString().substr(0, 10) %> • Placed on <%= orderInfo.order_date.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></p>
    </div>
  </section>

  <section class="content-main">
    <div class="container">
      <div class="card border-0 shadow-sm rounded-3 bg-white mb-4 overflow-hidden">
        
        <!-- Header Row -->
        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center justify-content-between">
          <div>
            <span class="text-muted text-xs d-block">ORDER REFERENCE</span>
            <h5 class="font-weight-bold text-dark mb-0" style="font-family: 'Playfair Display', serif;">#<%= orderInfo._id.toString().substr(0, 10) %></h5>
          </div>

          <% if (orderInfo.order_status === 'delivered') { %>
            <a class="btn btn-sm btn-outline-success rounded-3 font-weight-bold px-3" href="/user/download-invoice/<%= orderInfo._id %>">
              <i class="fa fa-file-text-o mr-1"></i> Download Invoice
            </a>
          <% } %>
        </div>

        <div class="card-body p-4">
          <!-- Visual Order Status Timeline -->
          <% if (orderInfo.order_status !== 'cancelled') { %>
            <% 
              let stepNum = 1;
              if (orderInfo.order_status === 'confirmed' || orderInfo.order_status === 'processing') stepNum = 2;
              else if (orderInfo.order_status === 'Shipped' || orderInfo.order_status === 'shipped') stepNum = 3;
              else if (orderInfo.order_status === 'delivered') stepNum = 4;
            %>
            <div class="order-status-timeline mb-5">
              <div class="timeline-step <%= stepNum >= 1 ? 'completed' : '' %>">
                <div class="timeline-icon"><i class="fa fa-shopping-cart"></i></div>
                <div class="timeline-label">Order Placed</div>
              </div>
              <div class="timeline-step <%= stepNum >= 2 ? 'completed' : '' %>">
                <div class="timeline-icon"><i class="fa fa-check"></i></div>
                <div class="timeline-label">Confirmed</div>
              </div>
              <div class="timeline-step <%= stepNum >= 3 ? 'completed' : '' %>">
                <div class="timeline-icon"><i class="fa fa-truck"></i></div>
                <div class="timeline-label">Shipped</div>
              </div>
              <div class="timeline-step <%= stepNum >= 4 ? 'completed' : '' %>">
                <div class="timeline-icon"><i class="fa fa-home"></i></div>
                <div class="timeline-label">Delivered</div>
              </div>
            </div>
          <% } else { %>
            <div class="alert alert-danger rounded-3 text-center my-4 p-4">
              <i class="fa fa-times-circle fa-2x mb-2 text-danger"></i>
              <h5 class="font-weight-bold mb-1">This order was Cancelled</h5>
              <p class="text-xs mb-0">Prepaid/wallet amounts have been credited back to your Organic Wallet.</p>
            </div>
          <% } %>

          <!-- 3 Columns Info Row -->
          <div class="row g-3 mb-4 p-3 rounded-3 bg-light border">
            <div class="col-md-4">
              <div class="d-flex align-items-start gap-3">
                <div class="rounded-3 bg-white border p-2.5 text-success d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                  <i class="fa fa-user"></i>
                </div>
                <div>
                  <h6 class="font-weight-bold text-dark text-sm mb-1">Customer Info</h6>
                  <p class="text-muted text-xs mb-0"><%= selectedAddress.fname %> <%= selectedAddress.lname %></p>
                  <p class="text-muted text-xs mb-0"><%= selectedAddress.phone %></p>
                </div>
              </div>
            </div>

            <div class="col-md-4">
              <div class="d-flex align-items-start gap-3">
                <div class="rounded-3 bg-white border p-2.5 text-success d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                  <i class="fa fa-truck"></i>
                </div>
                <div>
                  <h6 class="font-weight-bold text-dark text-sm mb-1">Dispatch Details</h6>
                  <p class="text-muted text-xs mb-0">Carrier: Express Organic Delivery</p>
                  <p class="text-muted text-xs mb-0">Status: <strong class="text-dark"><%= orderInfo.order_status %></strong></p>
                </div>
              </div>
            </div>

            <div class="col-md-4">
              <div class="d-flex align-items-start gap-3">
                <div class="rounded-3 bg-white border p-2.5 text-success d-flex align-items-center justify-content-center" style="width: 42px; height: 42px;">
                  <i class="fa fa-map-marker"></i>
                </div>
                <div>
                  <h6 class="font-weight-bold text-dark text-sm mb-1">Delivery Address</h6>
                  <p class="text-muted text-xs mb-0"><%= selectedAddress.address %></p>
                  <p class="text-muted text-xs mb-0"><%= selectedAddress.city %>, <%= selectedAddress.state %> - <%= selectedAddress.pincode %></p>
                </div>
              </div>
            </div>
          </div>

          <!-- Items Table & Price Summary Row -->
          <div class="row g-4">
            <div class="col-lg-8">
              <div class="table-responsive">
                <table class="table align-middle mb-0">
                  <thead class="bg-light">
                    <tr>
                      <th class="ps-3">Item Product</th>
                      <th>Quantity</th>
                      <th class="text-end pe-3">Subtotal</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (orderInfo.items && orderInfo.items.length > 0) { %>
                      <% orderInfo.items.forEach(function(item) { %>
                        <tr>
                          <td class="ps-3">
                            <div class="d-flex align-items-center gap-3">
                              <img src="<%= item.productImage %>" alt="<%= item.productName %>" width="50" height="50" class="rounded-3 border object-fit-cover" />
                              <span class="font-weight-bold text-dark text-sm"><%= item.productName %></span>
                            </div>
                          </td>
                          <td class="font-weight-bold text-dark text-sm"><%= item.quantity %> pack(s)</td>
                          <td class="text-end pe-3 font-weight-bold text-success text-sm">₹<%= item.price %></td>
                        </tr>
                      <% }); %>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Price Calculations & Action Buttons -->
            <div class="col-lg-4">
              <div class="card border-0 shadow-xs rounded-3 p-4 bg-light">
                <h6 class="font-weight-bold text-dark mb-3">Order Price Summary</h6>

                <div class="d-flex justify-content-between text-xs text-muted mb-2">
                  <span>Subtotal:</span>
                  <span class="font-weight-bold text-dark">₹<%= orderInfo.subTotal || orderInfo.total_amount %></span>
                </div>

                <% if (orderInfo.discount && orderInfo.discount > 0) { %>
                  <div class="d-flex justify-content-between text-xs text-danger mb-2">
                    <span>Discount Coupon:</span>
                    <span class="font-weight-bold">-₹<%= orderInfo.discount %></span>
                  </div>
                <% } %>

                <div class="d-flex justify-content-between text-xs text-muted mb-3">
                  <span>Payment Method:</span>
                  <span class="badge bg-success bg-opacity-10 text-success rounded-pill font-weight-bold text-xs"><%= orderInfo.payment_method %></span>
                </div>

                <div class="d-flex justify-content-between font-weight-bold text-dark pt-3 border-top mb-4" style="font-size: 18px;">
                  <span>Grand Total:</span>
                  <span class="text-success font-weight-bold">₹<%= orderInfo.total_amount %></span>
                </div>

                <% if (orderInfo.order_status !== 'cancelled' && orderInfo.order_status !== 'delivered') { %>
                  <button type="button" class="btn btn-danger w-100 rounded-pill py-2.5 font-weight-bold text-sm" onclick="cancelOrder('<%= orderInfo._id %>')">
                    Cancel Order
                  </button>
                <% } else { %>
                  <a href="/user/shopping" class="btn btn-primary-organic w-100 rounded-pill py-2.5 font-weight-bold text-sm">
                    Continue Shopping
                  </a>
                <% } %>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/userFooter.ejs')%>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  function cancelOrder(orderId) {
    Swal.fire({
      title: 'Cancel this order?',
      text: "Prepaid or wallet payments will be immediately refunded to your Organic Wallet.",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#0F4C3A',
      confirmButtonText: 'Yes, Cancel Order'
    }).then((result) => {
      if (result.isConfirmed) {
        $.ajax({
          url: "/user/cancelOrder/" + orderId,
          method: "post",
          success: function() {
            location.reload();
          }
        });
      }
    });
  }
</script>
