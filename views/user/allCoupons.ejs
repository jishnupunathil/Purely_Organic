<%-include('../partials/userHeader.ejs')%>

<main class="bg-light pb-5" style="min-height: 80vh;">
  <!-- Page Banner -->
  <section class="py-4 text-white text-center rounded-4 mb-4 mx-3 shadow-sm" style="background: linear-gradient(135deg, #093327 0%, #0F4C3A 100%); border-radius: 20px !important;">
    <div class="container">
      <h1 class="font-weight-bold text-white mb-1" style="font-family: 'Playfair Display', serif; font-size: 32px;">Exclusive Offers & Coupons</h1>
      <p class="text-white-50 text-sm mb-0">Save big on your organic harvest orders with discount vouchers</p>
    </div>
  </section>

  <section class="coupons-section">
    <div class="container">
      <% if (typeof coupons !== 'undefined' && coupons && coupons.length > 0) { %>
        <div class="row g-4">
          <% coupons.forEach(function(element) { %>
            <% if (element?.days_remaining > 0) { %>
              <div class="col-lg-4 col-md-6">
                <div class="coupon-card bg-white p-4 rounded-4 shadow-sm border-2 position-relative h-100 d-flex flex-column justify-content-between transition-smooth hover-translate-y" style="border: 2px dashed #10B981; background: linear-gradient(135deg, #ffffff 0%, #F0FDF4 100%);">
                  
                  <!-- Top Badge Row -->
                  <div>
                    <div class="d-flex align-items-center justify-content-between mb-3">
                      <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1 font-weight-bold text-xs">
                        <i class="fa fa-percent mr-1"></i> <%= element.discount %>% OFF
                      </span>
                      <span class="badge bg-warning bg-opacity-10 text-warning rounded-pill px-2.5 py-1 text-xs font-weight-bold">
                        <i class="fa fa-clock-o mr-1"></i> <%= element.days_remaining %> days left
                      </span>
                    </div>

                    <!-- Code Box -->
                    <div class="d-flex align-items-center justify-content-between p-3 rounded-3 mb-3" style="background: #E6F4EA; border: 1px dashed #10B981;">
                      <code class="coupon-code font-weight-bold text-success" style="font-size: 20px; font-family: monospace; letter-spacing: 2px;"><%= element.code %></code>
                      <button type="button" class="btn btn-sm btn-success rounded-pill font-weight-bold text-xs px-3" onclick="copyCouponCode('<%= element.code %>')">
                        Copy Code
                      </button>
                    </div>

                    <!-- Discount Specs -->
                    <div class="text-xs text-muted mb-2">
                      <p class="mb-1"><i class="fa fa-check-circle text-success mr-1"></i> Maximum Discount Limit: <strong class="text-dark">₹<%= element.maxdiscount %></strong></p>
                      <p class="mb-0"><i class="fa fa-calendar text-muted mr-1"></i> Expiry Date: <strong class="text-dark"><%= new Date(element.expirationDate).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></strong></p>
                    </div>
                  </div>

                  <!-- Quick Use Shortcut -->
                  <div class="pt-3 border-top mt-3">
                    <a href="/user/getCart" class="btn btn-outline-success w-100 rounded-pill font-weight-bold text-xs py-2">
                      Use in Cart <i class="fa fa-arrow-right ml-1"></i>
                    </a>
                  </div>
                </div>
              </div>
            <% } %>
          <% }); %>
        </div>
      <% } else { %>
        <!-- Empty Coupons State -->
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white max-w-500 mx-auto" style="max-width: 500px;">
          <div class="rounded-circle bg-warning bg-opacity-10 text-warning d-inline-flex align-items-center justify-content-center mb-3 mx-auto" style="width: 70px; height: 70px; font-size: 32px;">
            <i class="fa fa-ticket"></i>
          </div>
          <h4 class="font-weight-bold text-dark mb-2" style="font-family: 'Playfair Display', serif;">No Coupons Active Right Now</h4>
          <p class="text-muted text-sm mb-4">Check back soon for new seasonal organic harvest discounts.</p>
          <a href="/user/shopping" class="btn btn-primary-organic rounded-pill px-4 py-2 font-weight-bold text-sm mx-auto">
            Explore Shop Catalog
          </a>
        </div>
      <% } %>
    </div>
  </section>
</main>

<%- include('../partials/userFooter.ejs')%>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  function copyCouponCode(code) {
    navigator.clipboard.writeText(code).then(() => {
      Swal.fire({
        toast: true,
        position: 'top-end',
        icon: 'success',
        title: `Coupon ${code} copied!`,
        showConfirmButton: false,
        timer: 2000
      });
    });
  }
</script>
