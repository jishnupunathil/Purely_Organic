<%-include('../partials/userHeader.ejs')%> 
<section class="hero hero-normal">
    <div class="container">
        <div class="row">
            <div class="col-lg-1">
                <% allBanner.forEach(function(banner) { %>
                    <%if(banner.bname==='ogani logo'){%>
                        <div class="header__logo">
                            <% if (user){%>
                                <a href="/user/index"><img src="<%=banner.bimages%>" alt=""></a>
                            <%}else{%>
                                <a href="/"><img src="<%=banner.bimages%>" alt=""></a>
                            <%}%>
                        </div>
                        <%}%>
                        <%})%>
            </div>
            <div class="col-lg-9">
                <nav class="header__menu">
                    <div class="hero__search">
                        <div class="hero__search__form">
                            <form action="/user/product-search/?search"  method="get" onsubmit="return validateForm()">
                                <div class="hero__search__categories">
                                    All Categories
                                    <span class="arrow_carrot-down"></span>
                                </div>
                                <input type="search" placeholder="What do yo u need?" name="search" id="product-search">
                                <button type="submit" class="site-btn">SEARCH</button>
                            </form>
                        </div>
                        <div class="hero__search__phone">
                            <div class="hero__search__phone__icon">
                                <i class="fa fa-phone"></i>
                            </div>
                            <div class="hero__search__phone__text">
                                <h5>+9496959109</h5>
                                <span>support 24/7 time</span>
                            </div>
                        </div>
                    </div>
                </nav>
            </div>
            <div class="col-lg-2">
                <div class="header__cart">
                    <ul>
                        <li><a href="/user/wishList"><i class="fa fa-heart"></i><span><%=wishCount%></span>  </a></li>
                        <li><a href="/user/getCart"><i class="fa fa-shopping-bag"></i><span><%=cartCount%></span></a></li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="humberger__open">
            <i class="fa fa-bars"></i>
        </div>
        </div>
    </div>
</section>
    <!-- Hero Section End -->

    <!-- Breadcrumb Section Begin -->
    <section class="breadcrumb-section set-bg" data-setbg="/img/breadcrumb.jpg">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 text-center">
                    <div class="breadcrumb__text">
                        <h2>Checkout</h2>
                        
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Breadcrumb Section End -->
    <div>
    </div>
    <!-- Checkout Section Begin -->
    <section class="checkout spad">
        <div class="container">
            <!-- Step Indicator -->
            <div class="checkout-steps">
                <div class="step-item active">
                    <div class="step-number">1</div>
                    <span>Cart</span>
                </div>
                <div class="step-line"></div>
                <div class="step-item active">
                    <div class="step-number">2</div>
                    <span>Shipping Address</span>
                </div>
                <div class="step-line"></div>
                <div class="step-item active">
                    <div class="step-number">3</div>
                    <span>Payment & Place Order</span>
                </div>
            </div>

            <div class="checkout__form">
                <h4 style="font-family: 'Playfair Display', serif; color: var(--primary-green); font-weight: 700;">Select Delivery Address</h4>
                <form id="checkout-form">
                    <div class="row">
                        <div class="col-lg-8 col-md-6 mb-4">
                            <div class="address-radio-group">
                                <%if(separateAddresses.length > 0){%>
                                    <%separateAddresses.forEach(function(address, index){%>
                                        <div class="address-radio-card <%= index === 0 ? 'selected' : '' %>">
                                            <input class="form-check-input" value="<%=address._id%>" type="radio" name="address" id="addressRadio_<%=address._id%>" <%= index === 0 ? 'checked' : '' %> />
                                            <div class="address-content-wrapper">
                                                <span class="address-tag">Saved Address <%=index+1%></span>
                                                <h5 style="font-weight: 700; color: var(--text-dark); margin-bottom: 6px;"><%=address.name || user.firstname%></h5>
                                                <p style="color: var(--text-muted); margin-bottom: 8px;">
                                                    <%=address.address%>, <%=address.city%>, <%=address.state%> - <%=address.pincode%>
                                                </p>
                                                <p style="font-size: 13px; color: var(--text-dark); margin-bottom: 12px;">
                                                    <strong>Phone:</strong> <%=address.phone%> | <strong>Email:</strong> <%=address.email%>
                                                </p>
                                                <div>
                                                    <a href="/user/editAddress/<%=address._id%>" class="btn btn-sm site-btn-organic" style="padding: 4px 14px !important; font-size: 13px;">Edit Address</a>
                                                </div>
                                            </div>
                                        </div>
                                    <%})%>
                                    <div class="mt-3">
                                        <a href="/user/newAddress" class="btn btn-outline-success site-btn-organic" style="background: transparent !important; color: var(--primary-green) !important; border: 2px solid var(--primary-green) !important;">+ Add New Shipping Address</a>
                                    </div>
                                <%}else{%>
                                    <div class="alert alert-warning p-4 rounded-3 text-center">
                                        <h5>No Saved Address Found!</h5>
                                        <p>Please add a shipping address to complete your order.</p>
                                        <a href="/user/newAddress" class="btn site-btn-organic mt-2">+ Add New Address</a>
                                    </div>
                                <%}%>
                            </div>
                            <input type="text" value="<%=user._id%>" name="userId" hidden>
                        </div>
                        <div class="col-lg-4 col-md-6">
                            <div class="checkout__order">
                                <h4>Your Order</h4>
                                <div class="checkout__order__products">Products <span>Total</span></div>
                                <% productDetails.forEach((prod)=>{%>
                                    <ul>
                                        <li><%=prod.name%><span>₹<%=prod.totalPrice%></span></li>
                                    </ul>
                                    <%})%>
                                <div class="checkout__order__subtotal" id="subTotal" name="subTotal">Subtotal <span>₹<%=total%></span></div>
                                <input type="text" value="<%=discountVal%>" name="discount" hidden>
                                <input type="text" value="<%=total%>" name="subTotal" hidden>
                                <div class="checkout__order__subtotal" id="discount" name="discount">Discount <span>₹<%=discountVal%></span></div>
                                <div class="checkout__order__total" id="totalPrice" name="totalPrice">Total <span>₹<%=subTotal%></div>
                                <div class="custom-control custom-radio">
                                    <input id="cod" value="cash_on_delivery" name="paymentMethod" type="radio" class="custom-control-input"/>
                                    <label class="custom-control-label" for="cod">Cash On Delivery</label>
                                </div>
                                <div class="custom-control custom-radio">
                                    <input id="online-payment" value="online_payment" name="paymentMethod" type="radio" class="custom-control-input"/>
                                    <label class="custom-control-label" for="online-payment">Online Payment</label>
                                </div>
                                  <div class="custom-control custom-radio">
                                    <input
                                      id="wallet"
                                      value="wallet"
                                      name="paymentMethod"
                                      type="radio"
                                      class="custom-control-input"
                                    />
                                    <label class="custom-control-label" for="wallet"
                                      >Wallet</label
                                    >
                                  </div>
                                  <div class="wallet-card">
                                    <h3>Wallet Balance</h3>
                                    
                                      <p>Use Wallet</p>
                                      <p class="wallet-amount">&#x20B9;0 </p>
                
                                  </div>
                                  <%if(separateAddresses.length>0){%>
                                <button type="submit" class="site-btn">PLACE ORDER</button>
                                  <%}else{%>
                                    <button type="submit" class="site-btn" disabled>PLACE</button>
                                    <p class="text-danger">Add Address to proceed!</p>
                                  <%}%>
                            </div>
                        </div>
                    </div>  
                </form>
            </div>
        </div>
        <div>
        </div>
    </section>
      </div>
                            </div>
                        </div>  
                    </form>
                </div>
            </div>
            <div>
            </div>
        </section>
        
    <!-- Checkout Section End -->
 
      
