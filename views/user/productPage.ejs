<%-include('../partials/userHeader.ejs')%>

<!-- Product Details Banner -->
<section class="py-4 text-white text-center rounded-3 mb-4 mx-3 shadow-sm" style="background: linear-gradient(135deg, #093327 0%, #0F4C3A 100%);">
  <div class="container">
    <h1 class="font-weight-bold text-white mb-1" style="font-family: 'Playfair Display', serif; font-size: 32px;"><%= singleProduct.pname %></h1>
    <p class="text-white-50 text-sm mb-0">100% Certified Farm-Fresh Organic Produce</p>
  </div>
</section>

<!-- Product Details Section Begin -->
<section class="product-details py-4">
  <div class="container">
    <div class="card border-0 shadow-sm rounded-3 p-4 bg-white mb-5">
      <div class="row align-items-center g-4">
        <!-- Product Image Gallery -->
        <div class="col-lg-6">
          <div class="product-main-image-box border rounded-3 p-3 bg-light text-center mb-3">
            <img
              class="img-fluid rounded-3 object-fit-contain"
              src="<%= singleProduct.pimages[0] %>"
              alt="<%= singleProduct.pname %>"
              style="max-height: 380px; width: 100%; object-fit: contain;"
              id="soom"
            />
          </div>
          <% if (singleProduct.pimages && singleProduct.pimages.length > 1) { %>
            <div class="d-flex gap-2 overflow-auto py-2">
              <% singleProduct.pimages.forEach(function(img) { %>
                <img
                  src="<%= img %>"
                  alt="<%= singleProduct.pname %>"
                  class="rounded-3 border cursor-pointer object-fit-cover"
                  style="width: 70px; height: 70px;"
                  onclick="document.getElementById('soom').src = this.src"
                />
              <% }); %>
            </div>
          <% } %>
        </div>

        <!-- Product Specs & Buy Box -->
        <div class="col-lg-6">
          <div class="product__details__text">
            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-1 text-xs font-weight-bold mb-2 d-inline-block">
              <i class="fa fa-leaf mr-1"></i> 100% Certified Organic
            </span>
            
            <h2 class="font-weight-bold text-dark mb-2" style="font-family: 'Playfair Display', serif; font-size: 32px; color: #0F4C3A;"><%= singleProduct.pname %></h2>

            <div class="rating-stars mb-3 text-warning" style="font-size: 14px;">
              <i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i>
              <span class="text-muted ml-2 text-xs">(4.9 Verified Customer Rating)</span>
            </div>

            <div class="product-price-tag mb-4">
              <span class="font-weight-bold text-success" style="font-size: 32px;">₹<%= singleProduct.pprice %></span>
              <span class="text-muted text-sm">/ 1 kg pack</span>
            </div>

            <!-- Organic Guarantee Box -->
            <div class="organic-guarantee-box p-3 rounded-3 mb-4 bg-light border d-flex justify-content-around text-center">
              <div class="guarantee-item">
                <i class="fa fa-leaf text-success d-block mb-1 font-20"></i>
                <span class="text-xs font-weight-bold text-dark d-block">100% Farm Fresh</span>
              </div>
              <div class="guarantee-item">
                <i class="fa fa-shield text-success d-block mb-1 font-20"></i>
                <span class="text-xs font-weight-bold text-dark d-block">Zero Pesticides</span>
              </div>
              <div class="guarantee-item">
                <i class="fa fa-truck text-success d-block mb-1 font-20"></i>
                <span class="text-xs font-weight-bold text-dark d-block">24h Express Transport</span>
              </div>
            </div>

            <!-- Availability & Specifications -->
            <ul class="list-unstyled text-sm text-dark mb-4 border-top border-bottom py-3">
              <li class="mb-2">
                <strong>Availability:</strong>
                <% if (singleProduct.pcountInStock === 0) { %>
                  <span class="badge bg-danger text-white rounded-pill px-2.5 py-1 text-xs ml-2">Out of Stock</span>
                <% } else { %>
                  <span class="badge bg-success text-white rounded-pill px-2.5 py-1 text-xs ml-2"><%= singleProduct.pcountInStock %> KG available in stock</span>
                <% } %>
              </li>
              <li class="mb-2"><strong>Shipping:</strong> <span class="text-muted">Free Express Delivery on orders above ₹149</span></li>
              <li class="mb-0"><strong>Standard Pack:</strong> <span class="text-muted">1 kg Net Weight</span></li>
            </ul>

            <!-- Buy Action Buttons -->
            <div class="d-flex align-items-center gap-3">
              <% if (singleProduct.pcountInStock === 0) { %>
                <button type="button" class="btn btn-secondary rounded-pill px-4 py-2.5 font-weight-bold text-sm" disabled>
                  Out Of Stock
                </button>
              <% } else { %>
                <button type="button" class="btn btn-primary-organic rounded-pill px-4 py-2.5 font-weight-bold text-sm shadow-sm" onclick="addToCart('<%= singleProduct._id %>')">
                  <i class="fa fa-shopping-bag mr-2"></i> ADD TO CART
                </button>
                <button type="button" class="btn btn-outline-danger rounded-pill px-3 py-2.5 font-weight-bold text-sm" onclick="AddToWishList('<%= singleProduct._id %>')" title="Save to Wishlist">
                  <i class="fa fa-heart"></i>
                </button>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Organic Products Section -->
    <% if (typeof allProduct !== 'undefined' && allProduct && allProduct.length > 0) { %>
      <div class="mt-5">
        <div class="text-center mb-4">
          <h3 class="font-weight-bold text-dark mb-1" style="font-family: 'Playfair Display', serif; color: #0F4C3A;">Related Organic Harvest</h3>
          <p class="text-muted text-sm">Customers who bought this item also explored</p>
        </div>

        <div class="row g-4">
          <% allProduct.slice(0, 4).forEach(function(product) { %>
            <div class="col-xl-3 col-lg-4 col-md-6 col-6">
              <div class="product-card-modern bg-white rounded-3 overflow-hidden border shadow-xs h-100 d-flex flex-column transition-smooth">
                <div class="badge-organic-seal">100% Organic</div>

                <div class="product-card-image-wrap position-relative overflow-hidden" style="height: 180px; background: #F8FAF6;">
                  <img src="<%= product.pimages[0] %>" alt="<%= product.pname %>" class="w-100 h-100 object-fit-cover" />
                </div>

                <div class="product-card-body p-3 d-flex flex-column flex-grow-1 justify-content-between">
                  <div>
                    <h6 class="mb-1">
                      <a href="<%= (typeof user !== 'undefined' && user) ? '/user/singleProductView/' + product._id : '/singleProductView/' + product._id %>" class="product-title font-weight-bold text-dark text-sm">
                        <%= product.pname %>
                      </a>
                    </h6>
                    <small class="text-muted d-block text-xs">Standard 1kg Pack</small>
                  </div>

                  <div class="product-price-row pt-2 mt-2 border-top d-flex align-items-center justify-content-between">
                    <span class="product-price font-weight-bold text-success" style="font-size: 18px;">₹<%= product.pprice %></span>
                    <% if (product.pcountInStock > 0) { %>
                      <button type="button" class="btn btn-sm btn-success rounded-3 font-weight-bold text-xs px-3" onclick="addToCart('<%= product._id %>')">+ Add</button>
                    <% } else { %>
                      <span class="badge bg-danger text-white rounded-3 px-2 py-1 text-xs">Out of Stock</span>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/userFooter.ejs')%>
