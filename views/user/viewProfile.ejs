<%-include('../partials/userHeader.ejs') %>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="profile-card">
                <div class="d-flex align-items-center gap-4 mb-4 pb-4 border-bottom">
                    <div class="profile-avatar">
                        <%= (profileData.firstname || 'U').charAt(0).toUpperCase() %>
                    </div>
                    <div>
                        <h3 class="mb-1" style="font-weight: 700; color: var(--primary-green);"><%=profileData.firstname%> <%=profileData.lastname%></h3>
                        <p class="text-muted mb-0"><i class="fa fa-envelope mr-2"></i><%=profileData.email%> | <i class="fa fa-phone mr-2"></i><%=profileData.phoneNumber%></p>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">First Name</label>
                        <input class="form-control" readonly value="<%=profileData.firstname%>" style="background: var(--bg-organic);">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Last Name</label>
                        <input class="form-control" readonly value="<%=profileData.lastname%>" style="background: var(--bg-organic);">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Email Address</label>
                        <input class="form-control" readonly value="<%=profileData.email%>" style="background: var(--bg-organic);">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label font-weight-bold">Phone Number</label>
                        <input class="form-control" readonly value="<%=profileData.phoneNumber%>" style="background: var(--bg-organic);">
                    </div>

                    <div class="col-12 mt-4">
                        <h5 class="mb-3" style="font-weight: 700; color: var(--primary-green);">Saved Addresses</h5>
                        <%if(address && address.length > 0){%>
                            <div class="row">
                                <% address.forEach(function(addr, index){%>
                                    <div class="col-md-6 mb-3">
                                        <div class="p-3 border rounded-3" style="background: var(--bg-organic);">
                                            <span class="address-tag">Address <%=index+1%></span>
                                            <p class="mb-1"><strong><%=addr.address%></strong>, <%=addr.city%></p>
                                            <p class="text-muted small mb-0"><%=addr.state%> - <%=addr.pincode%></p>
                                        </div>
                                    </div>
                                <%})%>
                            </div>
                        <%}else{%>
                            <div class="alert alert-light border text-muted">No saved addresses found.</div>
                        <%}%>
                    </div>
                </div>

                <div class="d-flex gap-3 mt-4 pt-3 border-top">
                    <a href="/user/editProfile" class="btn site-btn-organic">Edit Profile</a>
                    <a href="/user/myOrders" class="btn btn-outline-secondary site-btn-organic" style="background: transparent !important; color: var(--text-dark) !important; border: 1px solid var(--border-light) !important;">My Orders</a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/userFooter.ejs')%>