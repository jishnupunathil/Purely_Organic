<%-include('../partials/userHeader.ejs')%> 

<main class="bg-light pb-5" style="min-height: 80vh;">
  <!-- Page Banner -->
  <section class="py-4 text-white text-center rounded-4 mb-4 mx-3 shadow-sm" style="background: linear-gradient(135deg, #093327 0%, #0F4C3A 100%); border-radius: 20px !important;">
    <div class="container">
      <h1 class="font-weight-bold text-white mb-1" style="font-family: 'Playfair Display', serif; font-size: 32px;">Add New Shipping Address</h1>
      <p class="text-white-50 text-sm mb-0">Enter your delivery address for fast organic harvest dispatch</p>
    </div>
  </section>

  <section class="address-form-section">
    <div class="container">
      <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 bg-white max-w-800 mx-auto" style="max-width: 800px;">
        <h4 class="font-weight-bold text-dark mb-4" style="font-family: 'Playfair Display', serif; color: #0F4C3A;">Shipping Address Details</h4>

        <form action="/user/addAddress" method="post" id="billing">
          <div class="row g-3">
            <div class="col-md-6 mb-3">
              <label class="form-label font-weight-bold text-xs text-dark">First Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control rounded-3" name="fname" placeholder="John" required />
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label font-weight-bold text-xs text-dark">Last Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control rounded-3" name="lname" placeholder="Doe" required />
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label font-weight-bold text-xs text-dark">Street Address <span class="text-danger">*</span></label>
            <input type="text" class="form-control rounded-3 mb-2" name="address" placeholder="House / Flat No, Street name, Landmark" required />
          </div>

          <div class="row g-3">
            <div class="col-md-4 mb-3">
              <label class="form-label font-weight-bold text-xs text-dark">Town / City <span class="text-danger">*</span></label>
              <input type="text" class="form-control rounded-3" name="city" placeholder="Kochi" required />
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label font-weight-bold text-xs text-dark">State / Province <span class="text-danger">*</span></label>
              <input type="text" class="form-control rounded-3" name="state" placeholder="Kerala" required />
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label font-weight-bold text-xs text-dark">Postcode / ZIP <span class="text-danger">*</span></label>
              <input type="number" class="form-control rounded-3" name="pincode" placeholder="682025" required />
            </div>
          </div>

          <div class="row g-3 mb-4">
            <div class="col-md-6 mb-3">
              <label class="form-label font-weight-bold text-xs text-dark">Phone Number <span class="text-danger">*</span></label>
              <input type="number" class="form-control rounded-3" name="phone" placeholder="9496959109" required />
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label font-weight-bold text-xs text-dark">Email Address</label>
              <input type="email" class="form-control rounded-3" name="email" placeholder="john@example.com" />
            </div>
          </div>

          <div class="d-flex align-items-center gap-3 pt-3 border-top">
            <button type="submit" class="btn btn-primary-organic rounded-pill px-4 py-2.5 font-weight-bold text-sm">
              Save Address
            </button>
            <a href="/user/checkOut" class="btn btn-outline-secondary rounded-pill px-4 py-2.5 font-weight-bold text-sm">
              Cancel
            </a>
          </div>
        </form>
      </div>
    </div>
  </section>
</main>

<%- include('../partials/userFooter.ejs')%>
