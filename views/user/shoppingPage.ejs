<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <%-include('../partials/userHeader.ejs')%> 
    <section class="hero hero-normal">
        <div class="container">
            <div class="row">
                <div class="col-lg-2">
                    <% allBanner.forEach(function(banner) { %>
                        <%if(banner.bname==='ogani logo'){%>
                            <div class="header__logo">
                                <a href="/user/index"><img src="<%=banner.bimages%>" alt=""></a>
                            </div>
                            <%}%>
                            <%})%>
                </div>
               
                <div class="col-lg-9">
                    <div class="hero__search">
                        <%if(user){%>
                            <div class="hero__search__form">
                                <form action="/user/product-search/?search"  method="get" onsubmit="return validateForm()">
                                    <div class="hero__search__categories">
                                        All Categories
                                        <span class="arrow_carrot-down"></span>
                                    </div>
                                    <input type="search" placeholder="What do yo u need?" name="search" id="product-search">
                                    <button type="submit" class="site-btn">SEARCH</button>
                                </form>
                            </div>
                         <%}else{%>
                             <div class="hero__search__form">
                                 <form action="/product-search/?search"  method="get" onsubmit="return validateForm()">
                                     <div class="hero__search__categories">
                                         All Categories
                                         <span class="arrow_carrot-down"></span>
                                     </div>
                                     <input type="search" placeholder="What do yo u need?" name="search" id="product-search">
                                     <button type="submit" class="site-btn">SEARCH</button>
                                 </form>
                             </div>
                         <%}%>
                        <div class="hero__search__phone">
                            <div class="header__cart">
                                <ul>
                                    <li><a href="/user/wishList"><i class="fa fa-heart"></i> <span class="wish-badge"><%=wishCount%></span> </a></li>
                                    <li><a href="/user/getCart"><i class="fa fa-shopping-bag"></i><span class="cart-badge"><%=cartCount%></span></a></li>
                                </ul>
                            </div>
                            
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Hero Section End -->

    <!-- Breadcrumb Section Begin -->
    <section class="breadcrumb-section set-bg" data-setbg="/img/breadcrumb.jpg">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 text-center">
                    <div class="breadcrumb__text">
                        <h2>Ogani Shop</h2>
                        
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Breadcrumb Section End -->

   

    <section class="featured spad">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="section-title">
                        <h2 id="allcategoryHead">All Category</h2>
                    </div>
                    <div class="featured__controls"> 
                        <ul>
                            <li class="active" data-filter="*">All</li>
                            <% for (let i=0; i<allCategory.length; i++) { %> 
                                <li data-filter=".<%=allCategory[i].cname.replace(' ','_')%>"><%=allCategory[i].cname%></li>
                                <% } %>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="row featured__filter g-4">
                <% allProduct.forEach(function(product) { %>
                <div class="col-lg-3 col-md-4 col-sm-6 mb-4 mix <%=product.pcategory.replace(' ','_')%>">
                    <div class="product-card-modern">
                        <div class="product-card-image-wrap">
                            <span class="badge-organic-seal">🌿 100% Organic</span>
                            <img src="<%=product.pimages[0]%>" alt="<%=product.pname%>" loading="lazy">
                            
                            <div class="product-card-actions">
                                <%if(product.pcountInStock > 0){%>
                                    <% if (user){%>
                                        <button type="button" class="btn-action-icon" onclick="AddToWishList('<%=product._id%>')" title="Add to Wishlist"><i class="fa fa-heart"></i></button>
                                        <button type="button" class="btn-action-icon" onclick="addToCart('<%=product._id%>')" title="Add to Cart"><i class="fa fa-shopping-cart"></i></button>
                                    <%}else{%>
                                        <a href="/user/wishList" class="btn-action-icon"><i class="fa fa-heart"></i></a>
                                        <a href="/user/getCart" class="btn-action-icon"><i class="fa fa-shopping-cart"></i></a>
                                    <%}%>
                                <%}%>
                            </div>
                        </div>
                        <div class="product-card-body">
                            <div>
                                <div class="rating-stars">
                                    <i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star"></i><i class="fa fa-star-half-o"></i>
                                    <span class="text-muted ml-1" style="font-size: 11px;">(4.8)</span>
                                </div>
                                <%if(user){%>
                                    <a href="/user/singleProductView/<%=product._id%>" class="product-title"><%=product.pname%></a>
                                <%}else{%>
                                    <a href="/singleProductView/<%=product._id%>" class="product-title"><%=product.pname%></a>
                                <%}%>
                            </div>
                            
                            <div class="product-price-row">
                                <div>
                                    <span class="product-price">₹<%=product.pprice%></span>
                                    <span class="text-muted" style="font-size: 12px; font-weight: 500;"> / 1kg</span>
                                </div>
                                <%if(product.pcountInStock === 0){%>
                                    <span class="badge out-of-stock-badge">Out of Stock</span>
                                <%}else{%>
                                    <span class="organic-badge" style="font-size: 10px;">In Stock</span>
                                <%}%>
                            </div>
                        </div>
                    </div>
                </div>
                <%})%>
            </div>
        </div>



        
    </section>
    <div class="pagination-area mt-15 mb-50 ">
        <nav aria-label="Page navigation example">
          <ul class="pagination justify-content-center">
            <% if (currentPage > 1) { %>
            <li class="page-item"><a class="page-link" href="?page=<%=currentPage-1%>"><i class="material-icons" style="font-size:15px">chevron_left</i></a></li>
            <% } %>
            <% for (let i = 1; i <= totalPages; i++) { %>
            <li class="page-item <% if (i === currentPage) { %>active<% } %>"><a class="page-link" href="?page=<%=i%>"><%=i%></a></li>
            <% } %>
            <% if (currentPage < totalPages) { %>
            <li class="page-item"><a class="page-link" href="?page=<%=currentPage+1%>"><i class="material-icons" style="font-size:15px">chevron_right</i></a></li>
            <% } %>
          </ul>
        </nav>
      </div>
 
    <!-- Product Section End -->


    <!-- Footer Section Begin -->
    <%- include('../partials/userFooter.ejs')%>   
    <!-- Footer Section End -->

    <!-- Js Plugins -->

    <script src="https://cdnjs.cloudflare.com/ajax/libs/paginationjs/2.1.5/pagination.min.js"></script>