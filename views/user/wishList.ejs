<%-include('../partials/userHeader.ejs')%> 

<main class="bg-light pb-5" style="min-height: 80vh;">
  <!-- Page Banner -->
  <section class="py-4 text-white text-center rounded-4 mb-4 mx-3 shadow-sm" style="background: linear-gradient(135deg, #093327 0%, #0F4C3A 100%); border-radius: 20px !important;">
    <div class="container">
      <h1 class="font-weight-bold text-white mb-1" style="font-family: 'Playfair Display', serif; font-size: 32px;">My Wishlist Favorites</h1>
      <p class="text-white-50 text-sm mb-0">Your saved organic products ready for quick purchase</p>
    </div>
  </section>

  <% if (typeof showList !== 'undefined' && showList.length > 0) { %>
    <section class="wishlist-section">
      <div class="container">
        <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden mb-4">
          <div class="card-header bg-white border-bottom py-3 px-4">
            <h5 class="mb-0 font-weight-bold text-dark" style="font-family: 'Playfair Display', serif;">Saved Items (<%= showList.length %>)</h5>
          </div>

          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead class="bg-light">
                  <tr>
                    <th class="ps-4">Product</th>
                    <th>Price</th>
                    <th>Stock Status</th>
                    <th>Add to Cart</th>
                    <th class="text-end pe-4">Remove</th>
                  </tr>
                </thead>
                <tbody>
                  <% showList.forEach(function(element) { %>
                    <tr>
                      <td class="ps-4">
                        <div class="d-flex align-items-center gap-3">
                          <img src="<%= element?.productId?.pimages[0] %>" alt="<%= element?.productId?.pname %>" width="60" height="60" class="rounded-3 border object-fit-cover" />
                          <div>
                            <h6 class="mb-0 font-weight-bold text-dark text-sm"><%= element?.productId?.pname %></h6>
                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2 py-0.5 text-xs font-weight-bold">100% Organic</span>
                          </div>
                        </div>
                      </td>
                      <td class="text-sm font-weight-bold text-dark">
                        ₹<%= element?.productId?.pprice %>
                      </td>
                      <td>
                        <% if (element?.productId?.pcountInStock !== 0) { %>
                          <span class="badge bg-success rounded-pill px-2.5 py-1 text-xs font-weight-bold">In Stock</span>
                        <% } else { %>
                          <span class="badge bg-danger rounded-pill px-2.5 py-1 text-xs font-weight-bold">Out of Stock</span>
                        <% } %>
                      </td>
                      <td>
                        <% if (element?.productId?.pcountInStock !== 0) { %>
                          <button type="button" class="btn btn-sm btn-outline-success rounded-pill px-3 py-1 font-weight-bold text-xs" onclick="addToCart('<%= element?.productId?._id %>')">
                            + Add to Cart
                          </button>
                        <% } else { %>
                          <span class="text-muted text-xs font-weight-bold">Unavailable</span>
                        <% } %>
                      </td>
                      <td class="text-end pe-4">
                        <button type="button" class="btn btn-sm btn-outline-danger rounded-circle p-0 d-inline-flex align-items-center justify-content-center" style="width: 32px; height: 32px;" onclick="removeFromWishList('<%= element?.productId?._id %>')">
                          <i class="fa fa-trash-o"></i>
                        </button>
                      </td>
                    </tr>
                  <% }); %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="text-left">
          <a href="/user/shopping" class="btn btn-outline-success rounded-pill px-4 py-2 font-weight-bold text-sm">
            <i class="fa fa-arrow-left mr-2"></i> Continue Shopping
          </a>
        </div>
      </div>
    </section>
  <% } else { %>
    <!-- Empty Wishlist State -->
    <div class="container py-5 text-center">
      <div class="card border-0 shadow-sm rounded-4 p-5 max-w-500 mx-auto bg-white" style="max-width: 520px;">
        <div class="rounded-circle bg-danger bg-opacity-10 text-danger d-inline-flex align-items-center justify-content-center mb-3 mx-auto" style="width: 80px; height: 80px; font-size: 36px;">
          <i class="fa fa-heart-o"></i>
        </div>
        <h3 class="font-weight-bold text-dark mb-2" style="font-family: 'Playfair Display', serif;">Your Wishlist is Empty</h3>
        <p class="text-muted text-sm mb-4">You haven't saved any organic products to your wishlist yet.</p>
        <a href="/user/shopping" class="btn btn-primary-organic rounded-pill px-4 py-2.5 font-weight-bold text-sm mx-auto">
          Explore Organic Products
        </a>
      </div>
    </div>
  <% } %>
</main>

<%- include('../partials/userFooter.ejs')%>